# Copie este arquivo para "application.properties" e preencha com as credenciais do seu Supabase.
# (application.properties está no .gitignore para não versionar senhas.)

spring.datasource.url=jdbc:postgresql://SEU_HOST:5432/postgres
spring.datasource.username=postgres
spring.datasource.password=SUA_SENHA
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=validate
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.show-sql=true

server.port=8080
